{
    "compilerOptions": {
        "target": "ES2020",
        "useDefineForClassFields": true,
        "lib": [
            "ES2020",
            "DOM",
            "DOM.Iterable"
        ],
        "module": "ESNext",
        "skipLibCheck": true,
        /* Bundler mode */
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "jsx": "react-jsx",
        /* Linting */
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noFallthroughCasesInSwitch": true,
        /* Path aliases */
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "../../engine/index.js": [
                "./src/types/engine-modules.d.ts"
            ],
            "../../engine/boundary": [
                "./src/types/engine-modules.d.ts"
            ],
            "../../engine/algorithms/decisionTree.js": [
                "./src/types/engine-modules.d.ts"
            ],
            "../../../../engine/algorithms/decisionTree.js": [
                "./src/types/engine-modules.d.ts"
            ]
        }
    },
    "include": [
        "src"
    ],
    "references": [
        {
            "path": "./tsconfig.node.json"
        }
    ]
}